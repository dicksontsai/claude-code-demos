{
  "hooks": {
    "PreToolUse": [
      {"hooks": [{ "type": "http", "url": "http://localhost:3001/hooks", "timeout": 5000 }]}
    ],
    "PostToolUse": [
      {"hooks": [{ "type": "http", "url": "http://localhost:3001/hooks", "timeout": 5000 }]}
